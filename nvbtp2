<script>
function go(page) {
  document.querySelectorAll('.pg').forEach(p => p.classList.remove('act'));
  document.getElementById('pg-' + page).classList.add('act');
  document.querySelectorAll('[data-p]').forEach(a => a.classList.toggle('act', a.dataset.p === page));
  window.scrollTo({top: 0, behavior: 'smooth'});
  setTimeout(initRv, 80);
  const titles = {home:'NVBTP – Accueil',about:'NVBTP – À Propos',services:'NVBTP – Services',projects:'NVBTP – Réalisations',contact:'NVBTP – Contact'};
  document.title = titles[page] || 'NVBTP';
}
function toggleM() { document.getElementById('mm').classList.toggle('open'); }
function closeM() { document.getElementById('mm').classList.remove('open'); }
window.addEventListener('scroll', () => {
  const n = document.getElementById('nav'), s = window.scrollY > 60;
  n.style.padding = s ? (window.innerWidth > 960 ? '9px 60px' : '9px 20px') : (window.innerWidth > 960 ? '14px 60px' : '13px 20px');
});
function initRv() {
  const els = document.querySelectorAll('.pg.act .rv:not(.vis)');
  const obs = new IntersectionObserver(e => e.forEach(el => { if (el.isIntersecting) el.target.classList.add('vis'); }), {threshold: 0.08});
  els.forEach(el => obs.observe(el));
}
initRv();
function filterP(cat, btn) {
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('act'));
  btn.classList.add('act');
  document.querySelectorAll('.ptile').forEach(t => { t.style.display = (cat === 'all' || t.dataset.c === cat) ? '' : 'none'; });
}
function toggleFaq(el) {
  const was = el.classList.contains('open');
  document.querySelectorAll('.faqitem').forEach(i => i.classList.remove('open'));
  if (!was) el.classList.add('open');
}
function submitForm(e) {
  e.preventDefault();
  const b = e.target.querySelector('.fsub');
  b.textContent = '✓ Message Envoyé !';
  b.style.background = '#27ae60';
  b.disabled = true;
  setTimeout(() => { b.textContent = 'Envoyer Ma Demande →'; b.style.ald = ''; b.disabled = false; e.target.reset(); }, 3500);
}
</script>
