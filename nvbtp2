<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NVBTP – La Nouvelle Vision du Bâtiment</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
:root{--or:#F47920;--orl:#FF9A45;--orp:#FFF0E0;--w:#FFFFFF;--ow:#FAF8F5;--lg:#F2EEE8;--g:#888880;--dg:#444440;--dk:#1A1A1A;--tx:#2C2C2A;}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:"DM Sans",sans-serif;background:var(--w);color:var(--tx);overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;width:100%;z-index:1000;padding:14px 60px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.97);backdrop-filter:blur(20px);border-bottom:2px solid var(--or);box-shadow:0 2px 20px rgba(244,121,32,.1);transition:padding .3s;}
.nlogo img{height:50px;width:auto;cursor:pointer;}
.nlinks{display:flex;gap:30px;list-style:none;}
.nlinks a{text-decoration:none;color:var(--dg);font-size:13px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;transition:color .3s;position:relative;cursor:pointer;}
.nlinks a::after{content:"";position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--or);transition:width .3s;}
.nlinks a:hover,.nlinks a.act{color:var(--or);}
.nlinks a:hover::after,.nlinks a.act::after{width:100%;}
.ncta{background:var(--or);color:#fff;padding:11px 26px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;clip-path:polygon(8px 0%,100% 0%,calc(100%-8px) 100%,0% 100%);transition:background .3s;}
.ncta:hover{background:var(--orl);}
.hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;}
.hbg span{width:24px;height:2px;background:var(--dk);transition:all .3s;}
.mmenu{display:none;position:fixed;top:72px;left:0;right:0;background:#fff;border-top:2px solid var(--or);padding:16px 20px;z-index:999;flex-direction:column;gap:0;box-shadow:0 10px 30px rgba(0,0,0,.1);}
.mmenu a{padding:14px 0;font-size:13px;letter-spacing:2px;text-transform:uppercase;font-weight:700;color:var(--dk);border-bottom:1px solid var(--lg);cursor:pointer;display:block;}
.mmenu a:last-child{border-bottom:none;}
.mmenu a.act{color:var(--or);}
.mmenu.open{display:flex;}

/* PAGES */
.pg{display:none;animation:pgIn .35s ease;}
.pg.act{display:block;}
@keyframes pgIn{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

/* SHARED */
.slabel{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--or);font-weight:700;display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.slabel::before{content:"";width:28px;height:2px;background:var(--or);}
.slabel.c{justify-content:center;}.slabel.c::before{display:none;}
.stitle{font-family:"Playfair Display",serif;font-size:clamp(28px,3.5vw,46px);line-height:1.15;font-weight:900;color:var(--dk);margin-bottom:14px;}
.stitle em{color:var(--or);font-style:italic;}
.phero{padding:148px 60px 76px;background:linear-gradient(135deg,var(--ow) 0%,var(--orp) 100%);position:relative;overflow:hidden;}
.phero::before{content:"";position:absolute;right:-80px;top:-80px;width:460px;height:460px;background:radial-gradient(circle,rgba(244,121,32,.07),transparent 70%);border-radius:50%;}
.phi{max-width:1300px;margin:0 auto;}
.bc{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--g);margin-bottom:14px;}
.bc span{color:var(--or);cursor:pointer;}
.ptitle{font-family:"Playfair Display",serif;font-size:clamp(42px,6vw,76px);font-weight:900;color:var(--dk);line-height:1.08;}
.ptitle em{color:var(--or);font-style:italic;}
.psub{font-size:15px;color:var(--dg);margin-top:14px;max-width:500px;line-height:1.8;}
.bp{background:var(--or);color:#fff;padding:15px 36px;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;clip-path:polygon(10px 0%,100% 0%,calc(100%-10px) 100%,0% 100%);transition:all .3s;display:inline-block;}
.bp:hover{background:var(--orl);transform:translateY(-2px);}
.bw{background:#fff;color:var(--or);padding:15px 36px;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;clip-path:polygon(10px 0%,100% 0%,calc(100%-10px) 100%,0% 100%);transition:all .3s;}
.bw:hover{background:var(--ow);}
.bol{color:var(--dk);font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;display:inline-flex;align-items:center;gap:8px;border-bottom:2px solid var(--or);padding-bottom:2px;cursor:pointer;transition:color .3s;}
.bol:hover{color:var(--or);}
.ctab{padding:90px 60px;text-align:center;background:linear-gradient(135deg,var(--or),var(--orl));overflow:hidden;}
.ctab h2{font-family:"Playfair Display",serif;font-size:clamp(28px,4vw,50px);font-weight:900;color:#fff;margin-bottom:14px;}
.ctab h2 em{font-style:italic;color:rgba(255,255,255,.85);}
.ctab p{font-size:15px;color:rgba(255,255,255,.9);max-width:480px;margin:0 auto 32px;line-height:1.8;}

/* REVEAL */
.rv{opacity:0;transform:translateY(32px);transition:opacity .7s,transform .7s;}
.rv.vis{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}.d4{transition-delay:.4s;}

/* FOOTER */
footer{background:var(--dk);padding:60px 60px 36px;}
.fi{max-width:1300px;margin:0 auto;}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:46px;padding-bottom:36px;border-bottom:1px solid rgba(255,255,255,.07);}
.flogo img{height:52px;width:auto;object-fit:contain;margin-bottom:12px;display:block;filter:brightness(0) invert(1);cursor:pointer;}
.fb p{font-size:13px;color:rgba(255,255,255,.4);line-height:1.8;}
.fc h4{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--or);margin-bottom:18px;font-weight:700;}
.fc ul{list-style:none;}.fc ul li{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:9px;cursor:pointer;transition:color .3s;}.fc ul li:hover{color:var(--or);}
.fbot{padding-top:26px;display:flex;justify-content:space-between;align-items:center;}
.fbot p{font-size:12px;color:rgba(255,255,255,.22);}.fbot span{color:var(--or);}

/* ── HOME ── */
.hero{height:100vh;position:relative;display:flex;align-items:center;overflow:hidden;}
.hbg2{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.93) 0%,rgba(255,255,255,.6) 50%,rgba(255,255,255,.88) 100%),url("https://plus.unsplash.com/premium_photo-1681691912442-68c4179c530c?q=80&w=871&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D") center/cover no-repeat;}
.hbg2::after{content:"";position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,rgba(255,255,255,.95) 100%);}
.hgrid{position:absolute;inset:0;opacity:.04;background-image:linear-gradient(var(--or) 1px,transparent 1px),linear-gradient(90deg,var(--or) 1px,transparent 1px);background-size:60px 60px;animation:gm 20s linear infinite;}
@keyframes gm{to{background-position:60px 60px;}}
.hc{position:relative;z-index:2;padding:0 60px;max-width:860px;}
.htag{display:inline-flex;align-items:center;gap:10px;margin-bottom:22px;opacity:0;animation:fu .8s .3s forwards;}
.htag span{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--or);font-weight:700;}
.htag::before,.htag::after{content:"";height:2px;background:var(--or);width:26px;}
.hero h1{font-family:"Playfair Display",serif;font-size:clamp(48px,7vw,86px);line-height:1.05;font-weight:900;color:var(--dk);opacity:0;animation:fu .9s .5s forwards;}
.hero h1 em{font-style:italic;color:var(--or);}
.hsub{margin-top:20px;font-size:16px;color:var(--dg);line-height:1.8;max-width:490px;opacity:0;animation:fu .9s .7s forwards;}
.htline{margin-top:10px;font-size:11px;color:var(--or);font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0;animation:fu .9s .8s forwards;}
.hact{margin-top:38px;display:flex;gap:18px;align-items:center;opacity:0;animation:fu .9s .9s forwards;}
.hstats{position:absolute;bottom:46px;right:60px;z-index:2;display:flex;gap:3px;opacity:0;animation:fu .9s 1.1s forwards;}
.sc{background:#fff;border-top:3px solid var(--or);padding:18px 24px;text-align:center;box-shadow:0 8px 28px rgba(244,121,32,.12);}
.sn{font-family:"Bebas Neue",sans-serif;font-size:40px;color:var(--or);line-height:1;letter-spacing:2px;}
.sl2{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--g);margin-top:4px;}
.sline{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);width:1px;height:46px;background:linear-gradient(to bottom,var(--or),transparent);animation:pp 2s ease-in-out infinite;z-index:2;}
@keyframes pp{0%,100%{opacity:.3;}50%{opacity:1;}}
@keyframes fu{from{opacity:0;transform:translateY(26px);}to{opacity:1;transform:translateY(0);}}

/* MARQUEE */
.mbar{background:var(--or);padding:12px 0;overflow:hidden;}
.mtrack{display:flex;animation:mq 28s linear infinite;white-space:nowrap;}
.mi{font-family:"Bebas Neue",sans-serif;font-size:14px;letter-spacing:3px;color:#fff;padding:0 34px;display:flex;align-items:center;gap:12px;}
.mi::after{content:"◆";font-size:7px;color:rgba(255,255,255,.5);}
@keyframes mq{to{transform:translateX(-50%);}}

/* HOME ABOUT */
.hab{padding:100px 60px;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;max-width:1300px;margin:0 auto;}
.habt{font-size:15px;color:var(--dg);line-height:1.9;margin-bottom:14px;}
.fc2{display:flex;align-items:center;gap:14px;margin-top:32px;padding:20px 24px;border:2px solid var(--orp);background:var(--ow);border-left:4px solid var(--or);}
.fav{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,var(--or),var(--orl));display:flex;align-items:center;justify-content:center;font-family:"Playfair Display",serif;font-size:17px;font-weight:900;color:#fff;flex-shrink:0;}
.fi2 strong{font-size:15px;font-weight:700;display:block;color:var(--dk);margin-bottom:3px;}
.fi2 span{font-size:11px;color:var(--or);letter-spacing:1.5px;text-transform:uppercase;}
.hav{position:relative;height:500px;}
.hm{position:absolute;top:0;right:0;width:75%;height:75%;overflow:hidden;box-shadow:0 18px 54px rgba(244,121,32,.14);}
.hm img{width:100%;height:100%;object-fit:cover;}
.hs2{position:absolute;bottom:0;left:0;width:50%;height:50%;overflow:hidden;box-shadow:0 14px 36px rgba(0,0,0,.09);}
.hs2 img{width:100%;height:100%;object-fit:cover;}
.hbadge{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:62px;height:62px;background:var(--or);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-family:"Bebas Neue",sans-serif;font-size:9px;color:#fff;z-index:10;letter-spacing:1px;}

/* HOME SERVICES */
.hsvc{padding:90px 60px;background:var(--ow);}
.hsvc-i{max-width:1300px;margin:0 auto;}
.sgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin-top:54px;}
.scard{background:#fff;padding:32px 24px;border-top:3px solid transparent;transition:all .3s;position:relative;overflow:hidden;}
.scard:hover{border-top-color:var(--or);transform:translateY(-6px);box-shadow:0 18px 46px rgba(244,121,32,.11);}
.snum{font-family:"Bebas Neue",sans-serif;font-size:34px;color:rgba(244,121,32,.08);position:absolute;top:12px;right:12px;transition:color .3s;}
.scard:hover .snum{color:rgba(244,121,32,.18);}
.sico{width:38px;height:38px;color:var(--or);margin-bottom:14px;}
.sname{font-family:"Playfair Display",serif;font-size:15px;font-weight:700;margin-bottom:7px;color:var(--dk);}
.sdesc{font-size:13px;color:var(--g);line-height:1.7;}

/* HOME PROJECTS */
.hproj{padding:90px 60px;max-width:1300px;margin:0 auto;}
.hph{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;}
.pgrid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:270px 270px;gap:4px;}
.pcard{position:relative;overflow:hidden;background:var(--lg);cursor:pointer;}
.pcard:first-child{grid-row:1/3;}
.pbg{width:100%;height:100%;background-size:cover;background-position:center;transition:transform .6s;}
.pcard:hover .pbg{transform:scale(1.07);}
.pov{position:absolute;inset:0;background:linear-gradient(to top,rgba(244,121,32,.88) 0%,transparent 55%);display:flex;flex-direction:column;justify-content:flex-end;padding:24px;opacity:0;transition:opacity .4s;}
.pcard:hover .pov{opacity:1;}
.pcat{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.8);margin-bottom:4px;}
.pname{font-family:"Playfair Display",serif;font-size:16px;font-weight:700;color:#fff;}

/* HOME WHY */
.hwhy{padding:90px 60px;background:var(--ow);}
.hwhy-i{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.wvis{position:relative;height:460px;}
.wimg{position:absolute;inset:0;background:url("https://images.unsplash.com/photo-1590736969955-71cc94901144?w=800&q=80") center/cover;}
.wbadge{position:absolute;bottom:-16px;right:-16px;width:120px;height:120px;background:var(--or);display:flex;flex-direction:column;align-items:center;justify-content:center;}
.wbadge strong{font-family:"Bebas Neue",sans-serif;font-size:46px;color:#fff;line-height:1;}
.wbadge span{font-size:9px;color:rgba(255,255,255,.9);letter-spacing:2px;text-transform:uppercase;text-align:center;font-weight:700;}
.flist{margin-top:32px;display:flex;flex-direction:column;gap:20px;}
.fi3{display:flex;gap:14px;align-items:flex-start;padding-bottom:20px;border-bottom:1px solid var(--lg);}
.fi3:last-child{border-bottom:none;padding-bottom:0;}
.fico{width:40px;height:40px;flex-shrink:0;background:var(--orp);border:2px solid rgba(244,121,32,.25);display:flex;align-items:center;justify-content:center;color:var(--or);}
.fico svg{width:16px;height:16px;}
.fbody strong{font-size:15px;font-weight:700;display:block;margin-bottom:3px;color:var(--dk);}
.fbody p{font-size:13px;color:var(--g);line-height:1.7;}

/* ABOUT */
.astory{padding:80px 60px;max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.at{font-size:15px;color:var(--dg);line-height:1.9;margin-bottom:14px;}
.vsec{padding:80px 60px;background:var(--ow);}
.vi{max-width:1300px;margin:0 auto;}
.vgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:50px;}
.vcard{background:#fff;padding:42px 32px;border-top:3px solid var(--orp);transition:all .3s;}
.vcard:hover{border-top-color:var(--or);transform:translateY(-5px);box-shadow:0 16px 40px rgba(244,121,32,.09);}
.vnum{font-family:"Bebas Neue",sans-serif;font-size:52px;color:rgba(244,121,32,.08);line-height:1;margin-bottom:9px;}
.vtitle{font-family:"Playfair Display",serif;font-size:18px;font-weight:700;color:var(--dk);margin-bottom:11px;}
.vdesc{font-size:13px;color:var(--g);line-height:1.8;}
.sstrip{background:var(--or);padding:56px 60px;}
.si{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.sti{text-align:center;padding:26px;}
.stbig{font-family:"Bebas Neue",sans-serif;font-size:56px;color:#fff;line-height:1;letter-spacing:3px;}
.stsub{font-size:10px;color:rgba(255,255,255,.7);letter-spacing:2px;text-transform:uppercase;margin-top:4px;}
.fsec{padding:80px 60px;max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:64px;align-items:center;}
.fport{background:var(--orp);width:100%;aspect-ratio:3/4;display:flex;align-items:center;justify-content:center;font-family:"Playfair Display",serif;font-size:88px;color:var(--or);font-weight:900;position:relative;}
.fplate{position:absolute;bottom:-14px;right:-14px;background:var(--or);padding:18px 24px;}
.fplate strong{font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:2px;display:block;color:#fff;}
.fplate span{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.85);}
.fbio{font-size:15px;color:var(--dg);line-height:1.9;margin-bottom:13px;}
.fquote{border-left:4px solid var(--or);padding:16px 20px;background:var(--orp);margin:22px 0;font-family:"Playfair Display",serif;font-size:15px;font-style:italic;color:var(--dk);}

/* SERVICES */
.sbig{display:grid;grid-template-columns:1fr 1fr;gap:4px;max-width:1300px;margin:40px auto 0;padding:0 60px;}
.sbig2{position:relative;overflow:hidden;min-height:296px;display:flex;flex-direction:column;justify-content:flex-end;background:var(--lg);}
.sbbg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .5s;}
.sbig2:hover .sbbg{transform:scale(1.05);}
.sbov{position:absolute;inset:0;background:linear-gradient(to top,rgba(244,121,32,.9) 0%,rgba(244,121,32,.25) 50%,transparent 100%);}
.sbc{position:relative;z-index:2;padding:32px;}
.sbn{font-family:"Bebas Neue",sans-serif;font-size:42px;color:rgba(255,255,255,.22);line-height:1;margin-bottom:5px;}
.sbname{font-family:"Playfair Display",serif;font-size:21px;font-weight:900;color:#fff;margin-bottom:5px;}
.sbdesc{font-size:13px;color:rgba(255,255,255,.85);line-height:1.6;}
.asvc{padding:76px 60px;background:var(--ow);}
.asvc-i{max-width:1300px;margin:0 auto;}
.sfgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin-top:50px;}
.sfcard{background:#fff;padding:32px 24px;border-top:3px solid var(--orp);transition:all .3s;}
.sfcard:hover{border-top-color:var(--or);transform:translateY(-5px);box-shadow:0 16px 40px rgba(244,121,32,.1);}
.psec{padding:80px 60px;max-width:1300px;margin:0 auto;}
.psteps{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:50px;position:relative;}
.psteps::before{content:"";position:absolute;top:36px;left:10%;right:10%;height:2px;background:linear-gradient(to right,var(--or),var(--orl));z-index:0;}
.pstep{text-align:center;position:relative;z-index:1;padding:0 12px;}
.pcircle{width:72px;height:72px;border-radius:50%;background:var(--or);display:flex;align-items:center;justify-content:center;font-family:"Bebas Neue",sans-serif;font-size:24px;color:#fff;margin:0 auto 16px;box-shadow:0 7px 20px rgba(244,121,32,.28);}
.ptit{font-family:"Playfair Display",serif;font-size:13px;font-weight:700;color:var(--dk);margin-bottom:6px;}
.pdesc{font-size:12px;color:var(--g);line-height:1.6;}

/* PROJECTS */
.fbar{padding:36px 60px 8px;max-width:1300px;margin:0 auto;display:flex;gap:4px;flex-wrap:wrap;}
.fbtn{padding:9px 20px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;background:transparent;color:var(--g);border:1.5px solid var(--lg);cursor:pointer;transition:all .3s;}
.fbtn.act,.fbtn:hover{background:var(--or);color:#fff;border-color:var(--or);}
.pmas{padding:16px 60px 80px;max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
.ptile{position:relative;overflow:hidden;cursor:pointer;}
.ptile.tall{grid-row:span 2;}
.ptile.wide{grid-column:span 2;}
.ptbg{width:100%;height:100%;min-height:280px;background-size:cover;background-position:center;transition:transform .5s;}
.ptile:hover .ptbg{transform:scale(1.06);}
.ptov{position:absolute;inset:0;background:linear-gradient(to top,rgba(244,121,32,.88) 0%,transparent 55%);opacity:0;transition:opacity .4s;display:flex;flex-direction:column;justify-content:flex-end;padding:24px;}
.ptile:hover .ptov{opacity:1;}
.ptcat{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.8);margin-bottom:4px;}
.ptname{font-family:"Playfair Display",serif;font-size:17px;font-weight:900;color:#fff;}
.ptyear{font-size:11px;color:rgba(255,255,255,.7);margin-top:3px;}
.tsec{padding:80px 60px;background:var(--ow);}
.ti{max-width:1300px;margin:0 auto;}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:50px;}
.tcard{background:#fff;padding:36px 28px;border-top:3px solid var(--orp);transition:all .3s;}
.tcard:hover{border-top-color:var(--or);box-shadow:0 13px 34px rgba(244,121,32,.08);}
.tstars{color:var(--or);font-size:15px;margin-bottom:12px;letter-spacing:3px;}
.ttxt{font-size:14px;color:var(--dg);line-height:1.8;font-style:italic;margin-bottom:16px;}
